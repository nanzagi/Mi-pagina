---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
// 1. EL IMPORT CLAVE
import Search from 'astro-pagefind/components/Search';

const posts = (await getCollection('blog'))
    .filter(post => post.data && post.data.pubDate)
    .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---
<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Espacio para el buscador */
			.search-container { margin-bottom: 3rem; }
			ul { display: flex; flex-wrap: wrap; gap: 2rem; list-style-type: none; margin: 0; padding: 0; }
			ul li { width: calc(50% - 1rem); }
			ul li img { border-radius: 12px; margin-bottom: 0.5rem; }
			@media (max-width: 720px) { ul li { width: 100%; } }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="search-container">
					<Search id="search" className="pagefind-ui" ui={{ showImages: false }} />
				</div>

				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={720} height={360} src={post.data.heroImage} alt="" />
								)}
								<h4 class="title">{post.data.title}</h4>
								<p class="date"><FormattedDate date={post.data.pubDate} /></p>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>