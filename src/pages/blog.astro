---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
    <section>
        <h2 style="color: #FFA500; font-size: 1.2rem; margin-bottom: 1rem;">SECCIÓN: ÚLTIMAS GUÍAS</h2>
        <ul style="list-style: none; padding: 0;">
            {
                posts.map((post) => (
                    <li style="border-left: 3px solid #8A2BE2; padding-left: 15px; margin-bottom: 15px;">
                        <a href={`/posts/${post.id}/`} style="text-decoration: none;">
                            <h6 style="color: #FF00FF; margin: 0; font-size: 1.1rem; font-weight: bold;">
                                {post.data.title}
                            </h6>
                        </a>
                        <p style="color: #4b5563; font-size: 0.8rem; margin: 5px 0 0 0;">
                            {post.data.pubDate.toLocaleDateString()}
                        </p>
                    </li>
                ))
            }
        </ul>
    </section>
    	</main>
	<Footer />
	</body>
</html>